@prefix ddhub: <http://ddhub.no/>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@base <http://ddhub.no/>.

<http://ddhub.no/DWISVocabularyLogicalDefinitions.Noun> a owl:Ontology;
    rdfs:label "DWIS Vocabulary Logical Definitions — Noun"^^xsd:string;
    rdfs:comment "OWL logical definitions for the top-level DWISNoun categories and their mutual disjointness."@EN;
    owl:imports <http://ddhub.no/DWISVocabulary>.

#################################################################
#    Disjoint class declarations
#################################################################

# DrillingDataPoint (the semantic reference to a signal) and DrillingSignal
# (the data structure holding the value) are distinct.
ddhub:DrillingDataPoint owl:disjointWith ddhub:DrillingSignal.

# The following top-level categories are all mutually disjoint: no individual can
# simultaneously belong to two of them.
[] a owl:AllDisjointClasses;
    owl:members (
        ddhub:Axis
        ddhub:Clock
        ddhub:DataEndPoint
        ddhub:DataFlowNode
        ddhub:DataProvider
        ddhub:DataType
        ddhub:DrillingDataPoint
        ddhub:DrillingSignal
        ddhub:Equipment
        ddhub:Location
        ddhub:ReferenceFrame
        ddhub:Telemetry
    ).
